{
  "name": "@knowllm/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "NODE_ENV=development ts-node -r tsconfig-paths/register src/main.ts",
    "start": "NODE_ENV=development ts-node -r tsconfig-paths/register src/main.ts",
